<?xml version="1.0" encoding="UTF-8"?>
<!--
    Configuração de testes contra MySQL (paridade de stack real).
    Uso: docker compose exec -T app composer test:mysql

    Difere de phpunit.xml apenas na base de dados: corre a mesma suite contra
    MySQL numa BD de teste DEDICADA (findocprocessor_testing), nunca a BD de
    desenvolvimento. Host/credenciais vêm do ambiente do container (mysql/findoc).
    Corre em série (sem paralelismo) para dispensar privilégio de CREATE DATABASE.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="redis"/>
        <env name="PERMISSION_CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="mysql" force="true"/>
        <env name="DB_DATABASE" value="findocprocessor_testing" force="true"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
