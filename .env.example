APP_NAME=FinDocProcessor
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=findocprocessor
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_STORE=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_PASSWORD=secret  # obrigatório em produção
REDIS_CACHE_DB=1

SANCTUM_TOKEN_EXPIRATION=480

# CORS — origens permitidas para o frontend (lista separada por vírgulas)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Administrador inicial (seed). Em produção, ADMIN_INITIAL_PASSWORD é obrigatória:
# sem ela o seed do admin é ignorado (não cria credencial fraca conhecida).
ADMIN_EMAIL=admin@findocprocessor.test
ADMIN_INITIAL_PASSWORD=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

FILESYSTEM_INBOX_PATH=inbox/
FILESYSTEM_PROCESSED_PATH=processed/
FILESYSTEM_TEMP_PATH=temp/
FILESYSTEM_MAX_FILE_SIZE=52428800
FILESYSTEM_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tif,.tiff,.bmp,.webp

# Extração por IA — pipeline PdfParser → OCR → LLM local → LLM cloud (ver #94-#98).
# Comentar/esvaziar qualquer var de uma camada desliga essa camada (fail-safe).
# LLM_*_PROVIDER identifica o provider Prism (Prism\Prism\Enums\Provider — 'ollama',
# 'anthropic', 'openai', 'openrouter', ...); trocar de provider é só esta var, sem
# alterações de código (ver config/extracao.php).
# Ollama: LLM_LOCAL_URL SEM sufixo /v1 (o provider faz POST api/chat); localmente
# http://localhost:11434, a partir de container http://host.docker.internal:11434.
# Modelo geral recomendado para extração de faturas PT: qwen2.5:7b-instruct (evitar
# variantes -coder). Ver docs/system_spec/07-testing.md (suite E2E).
LLM_LOCAL_PROVIDER=ollama
LLM_LOCAL_URL=
LLM_LOCAL_MODEL=
LLM_CLOUD_PROVIDER=anthropic
LLM_CLOUD_URL=
LLM_CLOUD_MODEL=
LLM_CLOUD_KEY=
# Timeout (segundos) da chamada HTTP ao LLM. O default do cliente Prism (~30s) é
# curto para modelos locais; 120-180 acomoda um 7B em CPU.
LLM_TIMEOUT_SEGUNDOS=120

# TTL (segundos) do lease de reivindicação das etapas de análise (#111): um documento
# reclamado há mais tempo que isto é considerado abandonado (worker morto) e pode ser
# recuperado por outro worker. Também espaça os retries de uma etapa que falha.
EXTRACAO_TTL_LEASE=300

# Pipeline — limiar (minutos) para considerar um Documento "preso" num estado
# transitório (AguardaEnvio/Enviado/AguardaResposta), varrido pelo ReconciliarFicheirosJob.
PIPELINE_RECONCILIACAO_LIMIAR_MINUTOS=15

# Scan de malware — ClamAV self-hosted (ver #91). Vazio desliga a camada
# (fail-safe, mesmo padrão de LLM_LOCAL_*/LLM_CLOUD_*).
CLAMAV_HOST=
CLAMAV_PORT=
CLAMAV_TIMEOUT_SEGUNDOS=5
